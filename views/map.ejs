<!DOCTYPE html>
<html>
  <head>
    <title>Map</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://unpkg.com/maplibre-gl@3.6.1/dist/maplibre-gl.css"
      rel="stylesheet"
    />
    <script src="https://unpkg.com/maplibre-gl@3.6.1/dist/maplibre-gl.js"></script>
    <link rel="stylesheet" href="/css/map.css" />
  </head>

  <body>
    <main class="page-layout">
      <div class="top-bar">
        <div class="legend-section">
          <h3>Environment Legend</h3>
          <div class="legend-row">
            <div class="legend-item">
              <span class="dot sunny"></span>
              Sunny
            </div>
            <div class="legend-item">
              <span class="dot shaded"></span>
              Shaded
            </div>
            <div class="legend-item">
              <span class="dot indoors"></span>
              Indoors
            </div>
          </div>
        </div>

        <div class="filter-section">
          <button onclick="filterMarkers('all')">Show All</button>
          <button onclick="filterMarkers('sunny')" class="sunny-btn">
            Sunny
          </button>
          <button onclick="filterMarkers('shaded')" class="shaded-btn">
            Shaded
          </button>
          <button onclick="filterMarkers('indoors')" class="indoors-btn">
            Indoors
          </button>
          <button id="toggleMarkers" class="toggle-btn">Hide Markers</button>
        </div>
      </div>

      <div class="map-wrapper">
        <div id="map"></div>
        <div id="sidePanel" class="side-panel closed">
          <button class="close-btn" onclick="closePanel()">×</button>
          <h2>Post Details</h2>
          <div id="panelContent"></div>
        </div>
      </div>
    </main>

    <script>
      window.MAPTILER_KEY = "<%= MAPTILER_KEY %>";
    </script>

    <script src="/js/map.js"></script>
  </body>
</html>
