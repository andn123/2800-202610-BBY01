
<%- include("partials/header", {css: css}) %>
    <main class="page-layout">
      <div class="top-bar">
        <div class="legend-section">
          <h3>Environment Legend</h3>
          <div class="legend-row">
            <div class="legend-item">
              <span class="dot sunny"></span>
              Sunny
            </div>
            <div class="legend-item">
              <span class="dot shaded"></span>
              Shaded
            </div>
            <div class="legend-item">
              <span class="dot indoors"></span>
              Indoors
            </div>
          </div>
        </div>

        <div class="filter-section">
          <button onclick="filterMarkers('all')">Show All</button>
          <button onclick="filterMarkers('sunny')" class="sunny-btn">
            Sunny
          </button>
          <button onclick="filterMarkers('shaded')" class="shaded-btn">
            Shaded
          </button>
          <button onclick="filterMarkers('indoors')" class="indoors-btn">
            Indoors
          </button>
          <button id="toggleMarkers" class="toggle-btn">Hide Markers</button>
        </div>
      </div>

    </main>

    <div class="map-layout">
      <!-- MAP -->
      <div id="map" data-locations='<%- JSON.stringify(locations) %>'></div>

      <!-- PANEL -->
      <div class="side-panel" id="panelBox">
        <div class="handle"></div>

        <!-- HEADER -->
        <div class="d-flex flex-column border-bottom">

          <!-- Tabs -->
          <ul class="nav nav-tabs w-100 nav-fill">
            <li class="nav-item">
              <button
                class="nav-link active w-100"
                onclick="showTab('info', event)"
              >
                Info
              </button>
            </li>
            <li class="nav-item">
              <button class="nav-link w-100" onclick="showTab('post', event)">
                Posts
              </button>
            </li>
            <li class="nav-item">
              <button class="nav-link w-100" onclick="showTab('recent', event)">
                Recent
              </button>
            </li>
          </ul>
        </div>

        <!-- CONTENT -->
        <div id="panel" class="panel-content">
          <div>Click a location</div>
          <div id="loading" class="loader"></div>
        </div>
      </div>
    </div>
    <script>
  window.mapApi ="<%- mapApi %>";
    </script>

    <script src="/js/map.js"></script>
  </body>
</html>
