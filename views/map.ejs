<%- include("partials/header", {css: css}) %>

    <div class="map-layout">
      <!-- MAP -->
      <div
  id="map"
  data-locations="<%= encodeURIComponent(JSON.stringify(locations)) %>"
></div>

      <!-- PANEL -->
      <div class="side-panel" id="panelBox">
        <div class="handle"></div>

        <!-- HEADER -->
        <div class="d-flex flex-column border-bottom">

          <!-- Tabs -->
          <ul class="nav nav-tabs w-100 nav-fill">
            <li class="nav-item">
              <button
                class="nav-link active w-100"
                onclick="showTab('info', event)"
              >
                Info
              </button>
            </li>
            <li class="nav-item">
              <button class="nav-link w-100" onclick="showTab('post', event)">
                Posts
              </button>
            </li>
            <li class="nav-item">
              <button class="nav-link w-100" onclick="showTab('recent', event)">
                Recent
              </button>
            </li>
          </ul>
        </div>

        <!-- CONTENT -->
        <div id="panel" class="panel-content">
          <div>Click a location</div>
          <div id="loading" class="loader"></div>
        </div>
      </div>
    </div>
    <script>
  window.mapApi ="<%- mapApi %>";
    </script>

    <script src="/js/map.js"></script>
  </body>
  </html>
