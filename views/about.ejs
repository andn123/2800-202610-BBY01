<%- include("partials/header", {css: css}) %>
<%- include("partials/back-button") %>

    <div class="page">
  <h2 class="sr-only" style="position:absolute;width:1px;height:1px;overflow:hidden">Vancooler about page preview</h2>

  <div class="hero">
    <i class="ti ti-sun-wind hero-icon" aria-hidden="true"></i>
    <h2>Stay cool, stay out</h2>
    <p>Vancooler recommends shaded outdoor spots and social activities matched to the weather — so you can enjoy Vancouver without the heat.</p>
  </div>

  <div style="margin-bottom:2.5rem">
    <div class="section-label">What we do</div>
    <div class="section-title"><i class="ti ti-sparkles" aria-hidden="true" style="font-size:18px;color:#1D9E75"></i>Features & innovations</div>
    <div class="features-grid">
      <div class="feature-card">
        <i class="ti ti-trees feature-icon" aria-hidden="true"></i>
        <span class="feature-text">Shade-based location recommendations</span>
      </div>
      <div class="feature-card">
        <i class="ti ti-confetti feature-icon" aria-hidden="true"></i>
        <span class="feature-text">Activity suggestions around each place</span>
      </div>
      <div class="feature-card">
        <i class="ti ti-sun feature-icon" aria-hidden="true"></i>
        <span class="feature-text">Weather-aware planning for hot days</span>
      </div>
      <div class="feature-card">
        <i class="ti ti-layout feature-icon" aria-hidden="true"></i>
        <span class="feature-text">Simple and user-friendly interface</span>
      </div>
      <div class="feature-card">
        <i class="ti ti-shield-check feature-icon" aria-hidden="true"></i>
        <span class="feature-text">Focus on outdoor comfort and safety</span>
      </div>
    </div>
  </div>

  <div class="section-label">Behind the project</div>
  <div class="section-title"><i class="ti ti-users" aria-hidden="true" style="font-size:18px;color:#1D9E75"></i>Our team</div>
  <div class="team-grid">
    <div class="team-card">
      <div class="avatar">AN</div>
