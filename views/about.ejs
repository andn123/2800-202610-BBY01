    </div>
    <div class="team-card">
      <div class="avatar">MS</div>
      <div class="team-name">Maneet Singh</div>
    </div>
    <div class="team-card">
      <div class="avatar">JL</div>
      <div class="team-name">Jonathan Lin</div>
    </div>
    <div class="team-card">
      <div class="avatar">TM</div>
      <div class="team-name">Tracee Miasco</div>
    </div>
    <div class="team-card">
      <div class="avatar">AL</div>
      <div class="team-name">Adam Locke</div>
    </div>
  </div>
</div>
