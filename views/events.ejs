<%- include('partials/header', { title: title, css: css }) %>

<body>
  <% if (typeof guideMode !== "undefined" && guideMode === true) { %>
    <div class="tutorial-overlay" id="eventsTutorial">
      <div class="tutorial-card">
        <button class="tutorial-close" id="closeTutorial">×</button>

        <h2>Welcome to Events</h2>

        <p>
          This page helps you find indoor events near your current location.
        </p>

        <div class="tutorial-step">
          <span>1</span>
          <p>Allow location access so we can find events near you.</p>
        </div>

        <div class="tutorial-step">
          <span>2</span>
          <p>Use the search bar to look for concerts, sports, festivals, or other events.</p>
        </div>

        <div class="tutorial-step">
          <span>3</span>
          <p>Use sorting to organize events by date or name.</p>
        </div>

        <div class="tutorial-step">
          <span>4</span>
          <p>You can turn off Guide Mode anytime from the dashboard.</p>
        </div>

        <button class="tutorial-btn" id="gotItTutorial">Got it</button>
      </div>
    </div>
  <% } %>

  <main class="events-page">
    <section class="events-header">
      <h1>Events Near You</h1>
      <p id="locationText">Finding your location...</p>

      <input 
        type="text" 
        id="eventSearch" 
        class="event-search" 
        placeholder="Search events, artists, or venues..."
      />
    </section>

    <div class="sort-dropdown">
      <button id="sortButton" class="sort-button" type="button">
        Date: Soonest First
        <span>⌄</span>
      </button>

      <div id="sortMenu" class="sort-menu">
        <button type="button" data-sort="date-asc">Date: Soonest First</button>
        <button type="button" data-sort="date-desc">Date: Latest First</button>
        <button type="button" data-sort="name-asc">Name: A to Z</button>
        <button type="button" data-sort="name-desc">Name: Z to A</button>
        <button type="button" data-sort="venue-asc">Venue: A to Z</button>
      </div>
    </div>

    <div class="location-search-box">
      <input
        type="text"
        id="addressInput"
        class="address-input"
        placeholder="Enter a city or address..."
      />

      <button id="addressSearchBtn" class="address-search-btn" type="button">
        Change Location
      </button>
    </div>

    <section id="statusBox" class="status-box">
      Loading nearby events...
    </section>

    <section id="eventsContainer" class="events-container"></section>

    <div id="loadMoreWrap" class="load-more-wrap hidden">
      <button id="loadMoreBtn" class="load-more-btn" type="button">
        Load More Events
      </button>
    </div>

    <div id="loadingSpinner" class="loading-spinner-wrap hidden">
      <div class="pokeball-loader">
        <div class="pokeball-center"></div>
      </div>
      <p>Loading more events...</p>
    </div>
  </main>

  <%- include('partials/footer', { js: js }) %>
</body>