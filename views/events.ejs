<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Events Near You</title>

  <link rel="stylesheet" href="/css/events.css" />
</head>
<body>
<body>
<main class="events-page">
    <section class="events-header">
      <h1>Events Near You</h1>
      <p id="locationText">Finding your location...</p>

      <input 
        type="text" 
        id="eventSearch" 
        class="event-search" 
        placeholder="Search events, artists, or venues..."
      />
    </section>
    <select id="sortSelect" class="event-sort">
  <option value="date-asc">Date: Soonest First</option>
  <option value="date-desc">Date: Latest First</option>
  <option value="name-asc">Name: A to Z</option>
  <option value="name-desc">Name: Z to A</option>
  <option value="venue-asc">Venue: A to Z</option>
</select>

    <section id="statusBox" class="status-box">
      Loading nearby events...
    </section>

    <section id="eventsContainer" class="events-container"></section>
  </main>

  <script src="/js/events.js"></script>
</body>
</body>
</html>