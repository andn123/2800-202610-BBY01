<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="snow-flake.png" />
    <title>Info Center</title>

    <link rel="stylesheet" href="/css/info-center.css" />
  </head>
  <body>
    <section class="help-hero">
      <nav class="help-navbar">
        <div class="logo">VanCooler</div>

        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/events">Events</a>
          <a href="/help-center">Help Center</a>
        </div>
      </nav>

      <div class="hero-content">
        <h1>Hi, how can we help?</h1>
        <p class="hero-subtitle">
          Step-by-step tutorials for every feature our app offers.
        </p>

        <div class="search-box">
          <input
            type="text"
            id="helpSearch"
            placeholder="Search tutorials..."
          />
        </div>

        <div class="support-tags">
          <span>events</span>
          <span>location</span>
          <span>weather</span>
          <span>account</span>
        </div>
      </div>
    </section>

    <main class="help-container">
      <section class="feature-grid">
        <a href="#search-events" class="feature-card">
          <div class="feature-icon">🔍</div>
          <h3>Search Events</h3>
          <p>
            Find events near you using your city, location, or search keywords.
          </p>
        </a>

        <a href="#change-location" class="feature-card">
          <div class="feature-icon">📍</div>
          <h3>Change Location</h3>
          <p>
            Manually update your city or address to discover events somewhere
            else.
          </p>
        </a>

        <a href="#sort-events" class="feature-card">
          <div class="feature-icon">↕️</div>
          <h3>Sort Events</h3>
          <p>Organize events by date, name, or other available filters.</p>
        </a>

        <a href="#weather-events" class="feature-card">
          <div class="feature-icon">🌦️</div>
          <h3>Weather-Based Events</h3>
          <p>Get recommendations based on the current weather conditions.</p>
        </a>

        <a href="#create-posts" class="feature-card placeholder-card">
          <div class="feature-icon">📝</div>
          <h3>Create Posts</h3>
          <p>Make posts about places ideal for different social activities.</p>
        </a>

        <a href="#view-map" class="feature-card placeholder-card">
          <div class="feature-icon">🗺️</div>
          <h3>View Map</h3>
          <p>Explore the map to find suitable activity spots in your area.</p>
        </a>
      </section>

      <section
        class="tutorial-section"
        id="search-events"
        data-title="search events"
      >
        <div class="tutorial-header">
          <h2>Search for events near you</h2>
          <a href="/events" class="pill">Go to Page</a>
        </div>

        <div class="steps-row">
          <div class="step-card">
            <div class="step-number">1</div>
            <h3>Open events</h3>
            <p>Go to the Events page from the bottom navigation or homepage.</p>
          </div>

          <div class="arrow">→</div>

          <div class="step-card">
            <div class="step-number">2</div>
            <h3>Allow location</h3>
            <p>
              Let the app access your location so it can find nearby events.
            </p>
          </div>

          <div class="arrow">→</div>

          <div class="step-card">
            <div class="step-number">3</div>
            <h3>Use the search bar</h3>
            <p>
              Type an event name, artist, city, or keyword into the search bar.
            </p>
          </div>

          <div class="arrow">→</div>

          <div class="step-card">
            <div class="step-number">4</div>
            <h3>View results</h3>
            <p>
              The matching events will appear as cards with details and links.
            </p>
          </div>
        </div>
      </section>

      <section
        class="tutorial-section"
        id="change-location"
        data-title="change location address city"
      >
        <div class="tutorial-header">
          <h2>Change your location manually</h2>
          <a href="/events" class="pill">Go to Page</a>
        </div>

        <div class="steps-row">
          <div class="step-card">
            <div class="step-number">1</div>
            <h3>Open events</h3>
            <p>Go to the Events page where nearby events are displayed.</p>
          </div>

          <div class="arrow">→</div>

          <div class="step-card">
            <div class="step-number">2</div>
            <h3>Find location input</h3>
            <p>
              Look for the address or city search field near the top of the
              page.
            </p>
          </div>

          <div class="arrow">→</div>

          <div class="step-card">
            <div class="step-number">3</div>
            <h3>Enter address</h3>
            <p>Type the city or address where you want to search for events.</p>
          </div>

          <div class="arrow">→</div>

          <div class="step-card">
            <div class="step-number">4</div>
            <h3>Update results</h3>
            <p>The app reloads events based on the new location you entered.</p>
          </div>
        </div>
      </section>

      <section
        class="tutorial-section"
        id="sort-events"
        data-title="sort events filter date"
      >
        <div class="tutorial-header">
          <h2>Sort and filter events</h2>
          <a href="/events" class="pill">Go to Page</a>
        </div>

        <div class="steps-row">
          <div class="step-card">
            <div class="step-number">1</div>
            <h3>Open events</h3>
            <p>Go to the Events page after events have loaded.</p>
          </div>

          <div class="arrow">→</div>

          <div class="step-card">
            <div class="step-number">2</div>
            <h3>Find sort menu</h3>
            <p>Use the sort dropdown or buttons near the search area.</p>
          </div>

          <div class="arrow">→</div>

          <div class="step-card">
            <div class="step-number">3</div>
            <h3>Choose option</h3>
            <p>Select how you want to organize the events, such as by date.</p>
          </div>

          <div class="arrow">→</div>

          <div class="step-card">
            <div class="step-number">4</div>
            <h3>Check results</h3>
            <p>The event cards update based on your selected sorting option.</p>
          </div>
        </div>
      </section>

      <section
        class="tutorial-section"
        id="weather-events"
        data-title="weather indoor outdoor recommendations"
      >
        <div class="tutorial-header">
          <h2>Get weather-based recommendations</h2>
          <a href="/events" class="pill">Go to Page</a>
        </div>

        <div class="steps-row">
          <div class="step-card">
            <div class="step-number">1</div>
            <h3>Allow location</h3>
            <p>Give the app permission to check your local weather.</p>
          </div>

          <div class="arrow">→</div>

          <div class="step-card">
            <div class="step-number">2</div>
            <h3>Check weather</h3>
            <p>The app reads the current weather conditions for your area.</p>
          </div>

          <div class="arrow">→</div>

          <div class="step-card">
            <div class="step-number">3</div>
            <h3>Get suggestions</h3>
            <p>
              Indoor or outdoor events are recommended depending on the weather.
            </p>
          </div>

          <div class="arrow">→</div>

          <div class="step-card">
            <div class="step-number">4</div>
            <h3>Pick an event</h3>
            <p>Choose the event that best fits your plans and conditions.</p>
          </div>
        </div>
      </section>

      <section
        class="tutorial-section placeholder-tutorial"
        id="create-posts"
        data-title="saved favourite events placeholder"
      >
        <div class="tutorial-header">
          <h2>Share a social spot</h2>
          <a href="/post" class="pill">Go to Page</a>
        </div>

        <div class="steps-row">
          <div class="step-card">
            <div class="step-number">1</div>
            <h3>Sign in</h3>
            <p>
              Sign in to your account; if already signed in, you can skip this
              step.
            </p>
          </div>

          <div class="arrow">→</div>

          <div class="step-card">
            <div class="step-number">2</div>
            <h3>Open post</h3>
            <p>Go to the Post page from the bottom navigation menu.</p>
          </div>

          <div class="arrow">→</div>

          <div class="step-card">
            <div class="step-number">3</div>
            <h3>Enter the information</h3>
            <p>Provide all information requested in the form.</p>
          </div>

          <div class="arrow">→</div>

          <div class="step-card">
            <div class="step-number">4</div>
            <h3>Click submit post</h3>
            <p>
              Click the Submit Post button to publish your post and continue to
              the posts page afterward.
            </p>
          </div>
        </div>
      </section>

      <section
        class="tutorial-section placeholder-tutorial"
        id="view-map"
        data-title="profile account login signup placeholder"
      >
        <div class="tutorial-header">
          <h2>Find nearby places on map</h2>
          <a href="/map" class="pill">Go to Page</a>
        </div>

        <div class="steps-row">
          <div class="step-card">
            <div class="step-number">1</div>
            <h3>Open map</h3>
            <p>Go to the Map page from the bottom navigation menu.</p>
          </div>

          <div class="arrow">→</div>

          <div class="step-card">
            <div class="step-number">2</div>
            <h3>Allow location</h3>
            <p>
              Let the app access your location so you can see where you are on
              the map.
            </p>
          </div>

          <div class="arrow">→</div>

          <div class="step-card">
            <div class="step-number">3</div>
            <h3>View marker legend</h3>
            <p>
              Learn what each color represents for different types of places.
            </p>
          </div>

          <div class="arrow">→</div>

          <div class="step-card">
            <div class="step-number">4</div>
            <h3>Filter activity spots</h3>
            <p>
              Choose which types of places you want to see on the map near your
              location.
            </p>
          </div>
        </div>
      </section>
    </main>

    <script src="/js/info-center.js"></script>
  </body>
</html>
