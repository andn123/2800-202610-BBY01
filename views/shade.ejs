<%- include("partials/header") %> 
        <div class="container-fluid position-relative px-0">
            <div id="map"></div> 

            <button
            id="backBtn"
            class="btn position-absolute top-0 start-0 m-3 d-flex align-items-center px-3 py-2 rounded-pill shadow border-0">
                <img src="/img/back.png" class="back-arrow me-2">
                <span class="fw-semibold">Back</span>
            </button>

            <div class="mode-button position-absolute top-0 end-0 m-2 d-flex flex-column gap-1">
                <button id="tree-mode" class="btn btn-light btn-sm d-flex align-items-center gap-2 shadow-sm">
                    <img src="/img/shade/tree2.png" width="16" height="16">
                    <span class="fw-semibold" >TreeMode</span>
                </button>
                <button id="spot-mode" class="btn btn-light btn-sm d-flex align-items-center gap-2 shadow-sm">
                    <img src="/img/shade/leaf.png" width="16" height="16"> 
                    <span class="fw-semibold">SpotMode</span>
                </button>
            </div>


            <% if (firstTime == true) { %>
                <%- include("partials/shadeFirstTimeView") %> 
            <% } else { %>
                <%- include("partials/shadeView") %> 
            <% } %>        
        </div>
<%- include("partials/footer") %> 